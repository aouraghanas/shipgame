generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  SCREEN
  ACCOUNTANT
  SOURCING_AGENT
  LIBYAN_ACCOUNTANT
  TASK_AGENT
  CONFIRMATION_AGENT
  CONFIRMATION_SCREEN
}

// Order-centric activity categories for call-center confirmation agents.
enum ConfirmationActivityCategory {
  CALL
  CONFIRMATION
  FOLLOW_UP
  NO_ANSWER
  RESCHEDULE
  CANCELLED
  OTHER
}

// Topics a confirmation agent can raise about orders/products/clients/prices.
enum ConfirmationFeedbackTopic {
  PRODUCT_QUALITY
  PRICING
  CLIENT_BEHAVIOR
  DELIVERY_ISSUE
  ORDER_DATA
  CANCELLATION_TREND
  OTHER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum ActivityCategory {
  CALL
  EMAIL
  MEETING
  ISSUE_FIX
  FOLLOW_UP
  OTHER
}

enum FeedbackTopic {
  FEATURE_REQUEST
  BUG_REPORT
  UX_IMPROVEMENT
  PRICING
  INTEGRATION
  SUPPORT
  OTHER
}

enum FeedbackSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum FeedbackReportPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum ActivityReportScope {
  GLOBAL
  SELLER
}

enum ActivityReportTrigger {
  MANUAL
  SCHEDULED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MANAGER)
  status       Status   @default(ACTIVE)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deliveredEntries   DeliveredEntry[]
  stockEntries       StockEntry[]
  notes              Note[]
  managerActivities  ManagerActivity[]
  sellerFeedbacks    SellerFeedback[]
  confirmationEntries    ConfirmationEntry[]
  confirmationActivities ConfirmationActivity[]
  confirmationFeedbacks  ConfirmationFeedback[]
  feedbackReports    FeedbackReport[] @relation("FeedbackReportCreator")
  activityReports    ActivityReport[]   @relation("ActivityReportCreator")
  accountingLedgerEntries AccountingLedgerEntry[] @relation("LedgerCreator")
  accountingAiReports     AccountingAiReport[]     @relation("AccountingAiCreator")
  cashOperations          CashOperation[]          @relation("CashOpCreator")
  ticketsCreated          SupportTicket[]          @relation("TicketCreator")
  ticketsAssigned         SupportTicket[]          @relation("TicketAssignee")
  ticketAttachments       SupportTicketAttachment[] @relation("TicketAttachmentUploader")
  ticketComments          SupportTicketComment[]   @relation("TicketCommentAuthor")
  userNotifications       UserNotification[]       @relation("UserNotifications")
  pushDevices             PushDevice[]             @relation("UserPushDevices")
  campaignsCreated        NotificationCampaign[]   @relation("CampaignCreator")
  campaignRecipients      CampaignRecipient[]      @relation("CampaignRecipientUser")
  leaderboardRankState    LeaderboardRankState[]   @relation("RankStateUser")

  taskBoardMemberships    TaskBoardMember[]        @relation("TaskBoardMembers")
  tasksReported           Task[]                   @relation("TaskReporter")
  taskAssignments         TaskAssignee[]           @relation("TaskAssigneeUser")
  taskComments            TaskComment[]            @relation("TaskCommentAuthor")
  taskActivities          TaskActivity[]           @relation("TaskActivityActor")
  taskChecklistChanges    TaskChecklistItem[]      @relation("TaskChecklistDoneBy")
}

// ——— Shipeh accounting (manual entry MVP; API sync later) ———

enum AccountingDirection {
  EXPENSE
  REVENUE
}

enum AccountingCurrency {
  LYD
  USD
  MAD
}

enum AccountingCategory {
  OFFICE_RENT
  OFFICE_OTHER
  SALARY_MOROCCO_DH
  SALARY_LIBYA_LYD
  STOCK_COD_DROP_PURCHASE
  ONLINE_INFRA
  TRANSFER_LIBYA_TO_USD_FEE
  OTHER_LOSS
  SHIPPING_MARGIN
  FULFILLMENT_MARGIN
  CALL_CENTER_INTERNAL
  CALL_CENTER_DEXPRESS
  LEAD_ENTRY_FEE
  COD_SERVICE_FEE_ON_COLLECTION
  OTHER_REVENUE
}

/// Global fee knobs (COD %, lead $, transfer % band). Edited by admins.
model AccountingSettings {
  id                    String   @id @default("singleton")
  codFeePercent         Decimal  @default(2) @db.Decimal(6, 3)
  leadFeeUsd            Decimal  @default(0.2) @db.Decimal(10, 4)
  transferFeePercentMin Decimal @default(0.1) @db.Decimal(6, 3)
  transferFeePercentMax Decimal @default(2) @db.Decimal(6, 3)
  updatedAt             DateTime @updatedAt
}

/// Per-city delivery: what Dexpress charges us vs what we sell to the seller (LYD).
model AccountingCityRate {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  dexpressCostLyd  Decimal  @db.Decimal(14, 3)
  sellToSellerLyd  Decimal  @db.Decimal(14, 3)
  active           Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([active, sortOrder])
}

/// Official LYD per 1 USD for a calendar day (Libya street / treasury rate you track).
model AccountingExchangeRate {
  id        String   @id @default(cuid())
  dateKey   String   @unique // YYYY-MM-DD
  lydPerUsd Decimal  @db.Decimal(16, 6)
  notes     String?
  createdAt DateTime @default(now())

  @@index([dateKey])
}

model AccountingLedgerEntry {
  id              String              @id @default(cuid())
  direction       AccountingDirection
  category        AccountingCategory
  amount          Decimal             @db.Decimal(18, 4)
  currency        AccountingCurrency
  amountUsdApprox Decimal?            @db.Decimal(18, 4)
  occurredAt      DateTime
  description     String
  metadata        Json?
  createdById     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  createdBy User @relation("LedgerCreator", fields: [createdById], references: [id])

  @@index([occurredAt])
  @@index([category])
  @@index([direction, currency])
}

model AccountingAiReport {
  id                String   @id @default(cuid())
  fromDate          DateTime
  toDate            DateTime
  generatedAt       DateTime @default(now())
  summary           String
  recommendations   String
  insights          Json?
  model             String?
  createdBy         String

  creator User @relation("AccountingAiCreator", fields: [createdBy], references: [id])

  @@index([fromDate, toDate])
  @@index([generatedAt])
}

// Delivered orders: one record per user per month (replace on update)
model DeliveredEntry {
  id        String   @id @default(cuid())
  userId    String
  monthKey  String   // YYYY-MM
  total     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey])
}

// Stock orders: additive entries per user per month
model StockEntry {
  id         String   @id @default(cuid())
  userId     String
  monthKey   String   // YYYY-MM
  quantity   Int
  sellerName String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Notes: at most one active visible note per user per month
model Note {
  id        String   @id @default(cuid())
  userId    String
  monthKey  String   // YYYY-MM
  content   String
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey])
}

// Audit log: tracks every mutation made by users
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String   // e.g. "stock.create", "profile.update", "avatar.upload"
  details   String   // human-readable description of what changed
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

// Shared seller list across all account managers
model Seller {
  id         String   @id @default(cuid())
  name       String
  email      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  activities     ManagerActivity[]
  feedbacks      SellerFeedback[]
  activityReports ActivityReport[]
  supportTickets SupportTicket[]

  @@index([name])
}

// Account manager activity log entries
model ManagerActivity {
  id          String           @id @default(cuid())
  managerId   String
  sellerId    String
  description String
  category    ActivityCategory @default(OTHER)
  attachments String[]         @default([])
  createdAt   DateTime         @default(now())

  manager User   @relation(fields: [managerId], references: [id])
  seller  Seller @relation(fields: [sellerId], references: [id])

  @@index([managerId])
  @@index([sellerId])
  @@index([createdAt])
}

model SellerFeedback {
  id              String            @id @default(cuid())
  managerId       String
  sellerId        String
  topic           FeedbackTopic     @default(OTHER)
  sentiment       FeedbackSentiment @default(NEUTRAL)
  title           String?
  details         String
  suggestedAction String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  manager User   @relation(fields: [managerId], references: [id])
  seller  Seller @relation(fields: [sellerId], references: [id])

  @@index([managerId])
  @@index([sellerId])
  @@index([createdAt])
  @@index([topic])
}

model FeedbackReport {
  id            String               @id @default(cuid())
  period        FeedbackReportPeriod
  fromDate      DateTime
  toDate        DateTime
  generatedAt   DateTime             @default(now())
  totalNotes    Int                  @default(0)
  repeatedItems Json?
  summary       String
  recommendations String
  model         String?
  createdBy     String

  creator User @relation("FeedbackReportCreator", fields: [createdBy], references: [id])

  @@index([period, fromDate, toDate])
  @@index([generatedAt])
}

model ActivityReport {
  id                String                 @id @default(cuid())
  period            FeedbackReportPeriod
  scope             ActivityReportScope
  sellerId          String?
  fromDate          DateTime
  toDate            DateTime
  generatedAt       DateTime               @default(now())
  totalActivities   Int                    @default(0)
  categoryBreakdown Json?
  managerBreakdown  Json?
  insights          Json?
  summary           String
  recommendations   String
  trigger           ActivityReportTrigger  @default(MANUAL)
  model             String?
  createdBy         String?

  creator User?   @relation("ActivityReportCreator", fields: [createdBy], references: [id])
  seller  Seller? @relation(fields: [sellerId], references: [id])

  @@index([period, fromDate, toDate])
  @@index([scope, sellerId])
  @@index([generatedAt])
}

model ActivityReportAutomation {
  id            String               @id @default("singleton")
  autoEnabled   Boolean              @default(false)
  autoPeriod    FeedbackReportPeriod @default(DAILY)
  lastAutoRunAt DateTime?
  updatedAt     DateTime             @updatedAt
}

// Notification bar management
enum NotificationType {
  INFO
  WARNING
  SUCCESS
  DANGER
  PROMO
}

enum NotificationFrequency {
  ALWAYS
  ONCE_PER_SESSION
  UNTIL_DISMISSED
}

model Notification {
  id            String                @id @default(cuid())
  title         String
  content       String
  type          NotificationType      @default(INFO)
  bgColor       String?
  textColor     String?
  icon          String?
  ctaText       String?
  ctaUrl        String?
  ctaNewTab     Boolean               @default(true)
  isActive      Boolean               @default(false)
  isDraft       Boolean               @default(true)
  isDismissible Boolean               @default(true)
  frequency     NotificationFrequency @default(ALWAYS)
  targetRoles   String[]              @default([])
  displayPages  String[]              @default(["leaderboard"])
  priority      Int                   @default(0)
  startAt       DateTime?
  endAt         DateTime?
  createdBy     String
  dismissCount  Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  dismissals    NotificationDismissal[]
}

model NotificationDismissal {
  id             String       @id @default(cuid())
  notificationId String
  userId         String
  createdAt      DateTime     @default(now())

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
}

// Monthly reward, punishment, and scoring configuration
model MonthConfig {
  id        String   @id @default(cuid())
  monthKey  String   @unique // YYYY-MM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Legacy single strings (fallback if per-place texts empty)
  rewardText     String?
  punishmentText String?

  /// How many top ranks show a reward line (1 = only 1st, 3 = podium)
  winnerPlaces Int @default(3)
  /// How many bottom ranks show punishment (1 = last only, 2 = last two)
  loserPlaces  Int @default(1)

  rewardText1     String?
  rewardText2     String?
  rewardText3     String?
  punishmentText1 String?
  punishmentText2 String?

  /// Delivered score = deliveredTotal / deliveredDivisor (e.g. 100 => 1 pt per 100 orders)
  deliveredDivisor Decimal @default(100) @db.Decimal(12, 4)
  /// Min stock qty for mid-tier points (e.g. 100)
  stockBoundaryMid  Int @default(100)
  /// Min stock qty for high-tier points (e.g. 200)
  stockBoundaryHigh Int @default(200)
  stockPointsLow    Int @default(1)
  stockPointsMid    Int @default(2)
  stockPointsHigh   Int @default(3)
  leaderboardDesign String @default("CLASSIC")

  /// ——— Confirmation-agent (call-center) scoring + rewards ———
  /// Points = treated*confTreatedPoints + confirmed*confConfirmedPoints + delivered*confDeliveredPoints
  confTreatedPoints   Decimal @default(1) @db.Decimal(12, 4)
  confConfirmedPoints Decimal @default(5) @db.Decimal(12, 4)
  confDeliveredPoints Decimal @default(20) @db.Decimal(12, 4)

  confWinnerPlaces Int @default(3)
  confLoserPlaces  Int @default(1)

  confRewardText1     String?
  confRewardText2     String?
  confRewardText3     String?
  confPunishmentText1 String?
  confPunishmentText2 String?
}

// Confirmation agents enter a running cumulative snapshot (since the 1st of the
// month) of orders treated / confirmed / delivered. One record per agent per
// month; each save replaces the previous snapshot (upsert).
model ConfirmationEntry {
  id        String   @id @default(cuid())
  userId    String
  monthKey  String   // YYYY-MM
  treated   Int      @default(0)
  confirmed Int      @default(0)
  delivered Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey])
}

// Order-centric activity log for confirmation agents (no seller — they only
// know the order, call the client to confirm and follow up).
model ConfirmationActivity {
  id          String                       @id @default(cuid())
  agentId     String
  orderRef    String
  description String
  category    ConfirmationActivityCategory @default(CALL)
  attachments String[]                     @default([])
  createdAt   DateTime                     @default(now())

  agent User @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([createdAt])
  @@index([orderRef])
}

// Order/product/client recommendations from confirmation agents.
model ConfirmationFeedback {
  id              String                    @id @default(cuid())
  agentId         String
  orderRef        String?
  topic           ConfirmationFeedbackTopic @default(OTHER)
  sentiment       FeedbackSentiment         @default(NEUTRAL)
  title           String?
  details         String
  suggestedAction String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  agent User @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([createdAt])
  @@index([topic])
}

// ——— Support tickets (managers + admins create; sourcing team + admins handle) ———

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  ARCHIVED
}

enum SupportTicketSubject {
  SOURCING
  PAYMENTS
  CALL_CENTER
  DELIVERY
  SHIPPING
  ORDERS
  PLATFORM
  WAREHOUSE
  PARTNER_LOGISTICS
  FINANCE
  PRODUCT_CATALOG
  TECH_SUPPORT
  ACCOUNTING
  OTHER
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketRecipient {
  ALL_ADMINS
  SPECIFIC_USER
  SOURCING_TEAM
}

model SupportTicket {
  id             String                 @id @default(cuid())
  createdById    String
  sellerId       String?
  sellerNameText String?
  subject        SupportTicketSubject
  priority       SupportTicketPriority    @default(NORMAL)
  deadlineAt     DateTime?
  title          String
  description    String                   @db.Text
  recipient      SupportTicketRecipient
  assigneeId     String?
  status         SupportTicketStatus      @default(OPEN)
  archivedAt     DateTime?
  resolvedAt     DateTime?
  resolutionNote String?                  @db.Text
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  createdBy   User                        @relation("TicketCreator", fields: [createdById], references: [id])
  assignee    User?                       @relation("TicketAssignee", fields: [assigneeId], references: [id])
  seller      Seller?                     @relation(fields: [sellerId], references: [id])
  attachments SupportTicketAttachment[]
  comments    SupportTicketComment[]

  @@index([status, createdAt])
  @@index([assigneeId])
  @@index([createdById])
  @@index([recipient, status])
  @@index([sellerId])
}

model SupportTicketAttachment {
  id           String   @id @default(cuid())
  ticketId     String
  url          String
  fileName     String
  mimeType     String
  size         Int
  uploadedById String
  createdAt    DateTime @default(now())

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User          @relation("TicketAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([ticketId])
}

model SupportTicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation("TicketCommentAuthor", fields: [userId], references: [id])

  @@index([ticketId])
}

// ——— Cashflow ledger v2 (BizWallet-style multi-currency wallet) ———
//
// Parallel to AccountingLedgerEntry while we test it. Same currencies
// (MAD/USD/LYD), same accountant access rules, but richer operation
// types and a native concept of "owed sellers". Balances are computed
// server-side from these rows on demand.

enum CashOperationType {
  ADD_BALANCE         // revenue +: top-up a currency directly
  FROM_DEX            // revenue +: DEX payout (LYD), nets out fulfillment + confirmation fees
  BUY_COD_PRODUCT     // expense −: buy a COD drop product
  BUY_SELLER_STOCK    // expense −: buy stock from supplier for a seller
  SELLER_PAY_STOCK    // neutral ⇄: seller pays for their stock (no balance change, audit only)
  CURRENCY_SWAP       // neutral ⇄: subtract origin currency, add destination currency
  SALARY              // expense −: pay a salary
  OFFICE_EXPENSE      // expense −: office overhead
  PAY_SHIPPING        // expense −: pay shipping for a sourcing arriving from China/Dubai
  WITHDRAW            // expense −: cash-out in USD (amount + fees subtracted)
  OTHER               // custom +/-: free-form
}

enum CashOperationDirection {
  REVENUE
  EXPENSE
  NEUTRAL
}

model CashOperation {
  id           String                  @id @default(cuid())
  type         CashOperationType
  direction    CashOperationDirection
  occurredAt   DateTime
  // Primary leg (always present)
  amount       Decimal                 @db.Decimal(18, 4)
  currency     AccountingCurrency
  // Destination leg — only for CURRENCY_SWAP
  destAmount   Decimal?                @db.Decimal(18, 4)
  destCurrency AccountingCurrency?
  description  String                  @db.Text
  note         String?                 @db.Text
  metadata     Json?
  // Optional evidence files (receipts, screenshots) — public storage URLs.
  attachments  String[]                @default([])
  createdById  String
  createdBy    User                    @relation("CashOpCreator", fields: [createdById], references: [id])
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([occurredAt(sort: Desc)])
  @@index([type])
  @@index([currency])
  @@index([direction, currency])
}

/// Sellers we owe money to. Single-row-per-seller — the amount is the
/// current outstanding balance, not a transaction. Mutated directly
/// from the Cashflow UI.
model OwedSeller {
  id        String              @id @default(cuid())
  name      String              @unique
  amount    Decimal             @default(0) @db.Decimal(18, 4)
  currency  AccountingCurrency  @default(USD)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

// ——— Per-user inbox notifications (ticket events, etc.) ———

enum UserNotificationKind {
  TICKET_ASSIGNED
  TICKET_FOR_YOU
  TICKET_COMMENT
  TICKET_STATUS_CHANGED
  TICKET_UNASSIGNED
  TASK_ASSIGNED
  TASK_UNASSIGNED
  TASK_COMMENT
  TASK_STATUS_CHANGED
  TASK_MENTION
  TASK_DUE_SOON
  LEADERBOARD_RANK_UP
  LEADERBOARD_RANK_DOWN
  ANNOUNCEMENT          // manual campaign blast
  GENERIC
}

model UserNotification {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  kind      UserNotificationKind  @default(GENERIC)
  title     String
  body      String?               @db.Text
  link      String?
  ticketId  String?
  taskId    String?
  // Set when this row originated from a manual admin campaign (for analytics).
  campaignId String?
  readAt    DateTime?
  createdAt DateTime              @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([campaignId])
}

// ——— Push notifications: registered Expo devices + manual campaigns ———

// One row per (user, device). The Expo push token is what we send to.
model PushDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("UserPushDevices", fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique          // Expo push token (ExponentPushToken[...])
  platform   String?                   // ios | android
  deviceName String?
  enabled    Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
}

enum CampaignAudience {
  ALL          // every active user
  ROLES        // a set of roles
  USERS        // an explicit set of users
}

// A manual notification blast composed by an admin. We keep it as a record so
// we can show simple analytics (how many recipients, how many read).
model NotificationCampaign {
  id           String              @id @default(cuid())
  title        String
  body         String?             @db.Text
  link         String?
  audience     CampaignAudience    @default(ALL)
  targetRoles  Role[]              @default([])
  createdById  String
  createdBy    User                @relation("CampaignCreator", fields: [createdById], references: [id])
  recipientCount Int               @default(0)
  pushSentCount  Int               @default(0)
  createdAt    DateTime            @default(now())

  recipients   CampaignRecipient[] @relation("CampaignRecipients")

  @@index([createdAt(sort: Desc)])
}

// Per-recipient row for a campaign — lets us track read state for analytics
// independently of the inbox UserNotification row.
model CampaignRecipient {
  id                 String               @id @default(cuid())
  campaignId         String
  campaign           NotificationCampaign @relation("CampaignRecipients", fields: [campaignId], references: [id], onDelete: Cascade)
  userId             String
  user               User                 @relation("CampaignRecipientUser", fields: [userId], references: [id], onDelete: Cascade)
  userNotificationId String?
  pushed             Boolean              @default(false)
  readAt             DateTime?
  createdAt          DateTime             @default(now())

  @@unique([campaignId, userId])
  @@index([userId])
}

// Snapshot of each user's last-seen leaderboard rank, per board, so we can
// detect rank changes between refreshes and notify the user.
model LeaderboardRankState {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("RankStateUser", fields: [userId], references: [id], onDelete: Cascade)
  board     String   // "managers" | "confirmation"
  monthKey  String
  rank      Int
  updatedAt DateTime @updatedAt

  @@unique([userId, board, monthKey])
}

// ——— Task manager (kanban boards, per-team workspaces) ———

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskBoardVisibility {
  PUBLIC      // everyone with task access (admins / managers / sourcing / accountant)
  TEAM_ONLY   // only explicit members + admins
  PRIVATE     // admins only
}

enum TaskActivityKind {
  CREATED
  TITLE_CHANGED
  DESCRIPTION_CHANGED
  PRIORITY_CHANGED
  STATUS_CHANGED        // column changed
  DUE_DATE_CHANGED
  ASSIGNEE_ADDED
  ASSIGNEE_REMOVED
  LABEL_ADDED
  LABEL_REMOVED
  CHECKLIST_ITEM_ADDED
  CHECKLIST_ITEM_COMPLETED
  CHECKLIST_ITEM_REMOVED
  COMMENT_ADDED
  ARCHIVED
  RESTORED
}

/// A kanban board, typically scoped to a team (Sourcing, Tech, Operations…)
model TaskBoard {
  id          String              @id @default(cuid())
  key         String              @unique         // short slug ("OPS", "TECH"…)
  name        String
  description String?             @db.Text
  color       String?                              // hex like "#a855f7" for the board chip
  icon        String?                              // optional emoji
  visibility  TaskBoardVisibility @default(PUBLIC)
  archived    Boolean             @default(false)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  columns  TaskColumn[]
  tasks    Task[]
  labels   TaskLabel[]
  members  TaskBoardMember[]

  @@index([archived, sortOrder])
}

/// Membership row for TEAM_ONLY / PRIVATE boards.
model TaskBoardMember {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  createdAt DateTime @default(now())

  board TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User      @relation("TaskBoardMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

/// Status column inside a board ("Backlog", "In progress", "Done"…)
model TaskColumn {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  color     String?
  position  Int      @default(0)
  isDone    Boolean  @default(false)  // marks the "Done" lane for completion analytics
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId, position])
}

model TaskLabel {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  color     String?
  createdAt DateTime @default(now())

  board       TaskBoard            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  assignments TaskLabelAssignment[]

  @@unique([boardId, name])
  @@index([boardId])
}

model TaskLabelAssignment {
  id      String @id @default(cuid())
  taskId  String
  labelId String

  task  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@index([labelId])
}

model Task {
  id          String       @id @default(cuid())
  boardId     String
  columnId    String
  title       String
  description String?      @db.Text
  priority    TaskPriority @default(NORMAL)
  position    Int          @default(0)
  dueAt       DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  archived    Boolean      @default(false)
  reporterId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  board     TaskBoard             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column    TaskColumn            @relation(fields: [columnId], references: [id])
  reporter  User?                 @relation("TaskReporter", fields: [reporterId], references: [id])
  assignees TaskAssignee[]
  labels    TaskLabelAssignment[]
  comments  TaskComment[]
  activity  TaskActivity[]
  checklist TaskChecklistItem[]

  @@index([boardId, archived])
  @@index([columnId, position])
  @@index([dueAt])
  @@index([priority])
}

model TaskAssignee {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskAssigneeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskComment {
  id        String    @id @default(cuid())
  taskId    String
  authorId  String
  body      String    @db.Text
  editedAt  DateTime?
  createdAt DateTime  @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("TaskCommentAuthor", fields: [authorId], references: [id])

  @@index([taskId, createdAt])
}

model TaskActivity {
  id        String           @id @default(cuid())
  taskId    String
  actorId   String?
  kind      TaskActivityKind
  payload   Json?
  createdAt DateTime         @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User? @relation("TaskActivityActor", fields: [actorId], references: [id])

  @@index([taskId, createdAt(sort: Desc)])
}

model TaskChecklistItem {
  id         String    @id @default(cuid())
  taskId     String
  label      String
  done       Boolean   @default(false)
  position   Int       @default(0)
  doneAt     DateTime?
  doneById   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  task   Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  doneBy User? @relation("TaskChecklistDoneBy", fields: [doneById], references: [id])

  @@index([taskId, position])
}
